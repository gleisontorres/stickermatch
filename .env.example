# Variáveis locais — copie para `.env.local` e preencha (ver PROMPT_CURSOR.md).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Seed (`yarn seed` / `npm run seed`): aplique antes `supabase/migrations/002_add_grupo.sql` no projeto (coluna grupo).
OPENAI_API_KEY=
# Opcional: sobrescreve o modelo padrão (gpt-5.4-nano).
# OPENAI_CHAT_MODEL=gpt-5.4-nano

# Migração SQL local (`yarn db:migrate`): senha em Dashboard → Database → Database password
SUPABASE_DB_PASSWORD=
# Ou URI Postgres direta para `yarn db:migrate`:
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# OAuth Google (Supabase Dashboard → Authentication → Providers → Google)
# + Redirect URLs: http://localhost:3000/callback e https://collecthub.app/callback
# + Site URL dev: http://localhost:3000 · produção: https://collecthub.app
